{
  "productName": "Anvil",
  "version": "0.1.0",
  "identifier": "app.anvil.desktop",
  "build": {
    "beforeBuildCommand": "pnpm export",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "13.0",
      "signingIdentity": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["anvil"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Anvil",
        "url": "/dashboard/",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "capsule",
        "title": "Anvil — Recording",
        "url": "/capsule/",
        "width": 420,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
