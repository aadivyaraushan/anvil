{
  "identifier": "default",
  "description": "Default capability set for Anvil desktop",
  "platforms": ["macOS"],
  "windows": ["main", "capsule"],
  "remote": {
    "urls": ["https://app.anvil-dev.com/*"]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "log:default",
    "store:default",
    "fs:default",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/recordings/**" }]
    }
  ]
}
