{
  "identifier": "default",
  "description": "Default capability set for Anvil desktop",
  "platforms": ["macOS"],
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://app.anvil-dev.com/*",
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "log:default",
    "store:default",
    "fs:default",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/recordings/**" }]
    }
  ]
}
