{
  "name": "desktop",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build --webpack",
    "export": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:tauri": "playwright test --config=e2e-tauri/playwright-tauri.config.ts",
    "test:e2e:tauri:built": "pnpm tauri:build:e2e && TAURI_E2E_LAUNCH_MODE=built playwright test --config=e2e-tauri/playwright-tauri.config.ts --grep @built",
    "check:tauri:e2e-symbols": "node scripts/check-tauri-e2e-symbols.mjs",
    "tauri": "tauri",
    "tauri:dev:e2e": "tauri dev --features e2e",
    "tauri:build:e2e": "tauri build --debug --features e2e --bundles app"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@deepgram/sdk": "^5.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.80.5",
    "@tanstack/react-query-devtools": "^5.80.5",
    "@tanstack/query-async-storage-persister": "^5.80.5",
    "@tanstack/react-query-persist-client": "^5.80.5",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-deep-link": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-log": "^2.5.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@srsholmes/tauri-playwright": "^0.2.0",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
